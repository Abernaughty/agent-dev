# Dev Suite Dashboard — Environment Variables
# Copy to .env and adjust as needed.
# Issue #37: SvelteKit API Routes & Providers

# FastAPI backend URL (no trailing slash)
BACKEND_URL=http://localhost:8000

# API secret for Bearer token auth (leave empty for dev mode)
API_SECRET=

# Set to "true" to use hardcoded mock data instead of hitting the backend.
# Useful for UI development when the FastAPI backend isn't running.
# Issue #38: Data Integration
PUBLIC_USE_MOCK_DATA=false
