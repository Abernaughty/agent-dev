# Dev Suite - Environment Configuration
# Copy this file to .env and fill in your keys
# NEVER commit .env to source control

# ============================================================
# API KEYS
# ============================================================

# Google (Architect + Planner agents)
GOOGLE_API_KEY=your-gemini-api-key-here

# Anthropic (Lead Dev + QA agents)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# E2B sandbox execution
E2B_API_KEY=your-e2b-api-key-here

# GitHub (PR publication via publish_code_node)
# Fine-grained PAT with Issues/PRs/Contents scope.
# If unset, publish_code_node is skipped gracefully.
# GITHUB_TOKEN=your-github-pat-here

# Langfuse observability
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key-here
LANGFUSE_SECRET_KEY=your-langfuse-secret-key-here
LANGFUSE_HOST=https://cloud.langfuse.com

# ============================================================
# AGENT MODELS
# ============================================================
# Each agent's model is configurable via env var. The model string
# is passed directly to the LangChain provider constructor.
#
# Provider routing:
#   ARCHITECT_MODEL  → ChatGoogleGenerativeAI (Google only)
#   DEVELOPER_MODEL  → ChatAnthropic (Anthropic only)
#   QA_MODEL         → ChatAnthropic (Anthropic only)
#   PLANNER_MODEL    → auto-detected by prefix:
#                      gemini* → Google, claude* → Anthropic,
#                      other → OpenAI-compatible fallback

# Architect agent — planning only, no tools, large context preferred.
# Acceptable values (Google Gemini):
#   gemini-3.1-pro-preview          — top reasoning, best for complex blueprints
#   gemini-3-flash-preview          — fast frontier quality (default)
#   gemini-2.5-pro                  — legacy, prefer 3.x family
#   gemini-2.5-flash                — DEPRECATED: shuts down June 1, 2026
ARCHITECT_MODEL=gemini-3-flash-preview

# Lead Dev agent — code generation, tool use (filesystem, GitHub).
# Acceptable values (Anthropic Claude):
#   claude-opus-4-6                 — flagship, 1M context, adaptive thinking
#   claude-sonnet-4-6               — latest Sonnet, 1M context, best computer use
#   claude-sonnet-4-5-20250929      — previous Sonnet, 200k context
#   claude-opus-4-5-20251101        — previous Opus, 200k context
#   claude-opus-4-1-20250805        — older Opus, 200k, $15/$75 per 1M
#   claude-sonnet-4-20250514        — Sonnet 4, retires no sooner than May 2026
#   claude-haiku-4-5-20251001       — fast/cheap, $1/$5 per 1M
DEVELOPER_MODEL=claude-sonnet-4-20250514

# QA agent — code review, structured failure reports, read-only tools.
# Same acceptable values as DEVELOPER_MODEL above.
# Lower temperature (0.0) is hardcoded for deterministic verdicts.
QA_MODEL=claude-opus-4-6

# Planner agent — lightweight task validation, zero tools, conversational.
# Accepts model IDs from any provider (auto-detected by prefix).
# Acceptable values (Google Gemini — recommended for cost):
#   gemini-3.1-flash-lite-preview   — cheapest 3.x, ideal for validation (default)
#   gemini-3-flash-preview          — more capable, higher cost
# Acceptable values (Anthropic Claude):
#   claude-haiku-4-5-20251001       — fast/cheap alternative
#   claude-sonnet-4-20250514        — overkill but works
PLANNER_MODEL=gemini-3.1-flash-lite-preview

# ============================================================
# INFRASTRUCTURE
# ============================================================

# E2B custom sandbox templates (built via `e2b template build`)
# See dev-suite/sandbox-templates/fullstack-dev/README.md for build instructions.
# Leave unset to use the default bare Python sandbox.
# E2B_TEMPLATE_DEFAULT=your-python-template-id
# E2B_TEMPLATE_FULLSTACK=your-fullstack-template-id

# ============================================================
# MEMORY LAYER
# ============================================================

# Backend: chroma-ephemeral | chroma-local (default) | chroma-server
MEMORY_BACKEND=chroma-local

# Chroma persistent storage directory (chroma-local only)
CHROMA_PERSIST_DIR=./chroma_data

# Chroma server connection (chroma-server only)
# CHROMA_HOST=localhost
# CHROMA_PORT=8000

# ============================================================
# WORKSPACE
# ============================================================

# Directory where agents write generated files (apply_code_node AND
# Dev agent filesystem_write tool calls during the tool loop).
#
# !! CRITICAL: Must point OUTSIDE dev-suite/ !!
#
# If WORKSPACE_ROOT resolves to dev-suite/ (or is left as "."), agent
# file writes trigger uvicorn --reload, killing the server mid-task.
# Symptoms: ERR_INCOMPLETE_CHUNKED_ENCODING in browser console,
# "ASGI callable returned without completing response" in uvicorn logs,
# dashboard shows "Reconnecting to backend..." and session state is lost.
#
# The code now auto-detects this and redirects to ../workspace, but
# setting it explicitly is recommended.
WORKSPACE_ROOT=../workspace

# --- Workspace Security (Issue #105) ---
# Comma-separated list of protected workspace patterns (literal matches).
# Can be local paths, GitHub repo names, or GitHub URLs.
# Patterns are matched literally (not globs or regex) — e.g., "agent-dev"
# matches paths containing that exact string as a directory component.
# Agents cannot write to these without PIN verification.
# Default always includes "agent-dev" detection (built-in).
# PROTECTED_WORKSPACES=agent-dev,my-infra-repo

# Bcrypt hash of the admin PIN for protected workspace access.
# Generate interactively (avoids PIN in shell history):
#   python -c "import getpass; from src.workspace import hash_pin; print(hash_pin(getpass.getpass('PIN: ')))"
# WORKSPACE_PROTECTED_PIN=$2b$12$...your-bcrypt-hash-here...

# ============================================================
# MCP TOOLS
# ============================================================

# Path to mcp-config.json for agent tools (Filesystem MCP, GitHub MCP, etc.)
# Defaults to dev-suite/mcp-config.json (relative to source code).
# Override if your config lives elsewhere.
# MCP_CONFIG_PATH=/absolute/path/to/mcp-config.json

# ============================================================
# ORCHESTRATOR TUNING
# ============================================================

# Max retries per task before escalating to human
MAX_RETRIES=3

# Token budget per task (approximate). Retries stop if exhausted.
TOKEN_BUDGET=50000

# Max tool call turns per agent invocation (Dev and QA tool loops).
# Higher = more autonomy, lower = faster/cheaper.
MAX_TOOL_TURNS=10

# Max chars of file content injected into retry prompts.
# Prevents context window exhaustion on large files during retries.
MAX_RETRY_FILE_CHARS=30000
